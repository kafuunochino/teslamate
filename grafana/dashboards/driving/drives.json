            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": true
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "consumption_kwh_$length_unit",
            "binary": {
              "left": "1000",
              "operator": "*",
              "right": "consumption_kWh / distance"
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": true
          }
        }
