# Copy this file to .env.native and replace every CHANGE_ME value.
# The native helper scripts load this file without evaluating shell commands.

ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARACTERS
SECRET_KEY_BASE=CHANGE_ME_LONG_RANDOM_SECRET
SIGNING_SALT=CHANGE_ME_RANDOM_SALT

DATABASE_USER=teslamate
DATABASE_PASS=CHANGE_ME_DATABASE_PASSWORD
DATABASE_NAME=teslamate
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Set to false and configure MQTT_HOST if Home Assistant/MQTT integration is needed.
DISABLE_MQTT=true
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

DEFAULT_LOCALE=zh_Hans
TZ=Asia/Shanghai
SKIP_LOCALE_DOWNLOAD=true
PORT=4000
HTTP_BINDING_ADDRESS=127.0.0.1
CHECK_ORIGIN=false
# For LAN access, also set VIRTUAL_HOST and CHECK_ORIGIN as documented in
# NATIVE_INSTALL.zh-CN.md. Keep the loopback defaults for local-only use.
# VIRTUAL_HOST=192.168.1.20
# CHECK_ORIGIN=http://192.168.1.20:4000

IMPORT_DIR=./import
SRTM_CACHE=./data/srtm
TZDATA_DIR=./data/tzdata

# Optional HTTP proxy for OpenStreetMap address lookup in mainland China.
# NOMINATIM_PROXY=http://127.0.0.1:7890
