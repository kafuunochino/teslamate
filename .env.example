# =============================================================================
# TeslaMate 默认环境变量示例
# =============================================================================
# 复制为 `.env` (cp .env.example .env) 后按需修改。
# 所有变量都设置了 "safe + compatible" 的默认值；如果环境变量未设置，
# TeslaMate 会读取下列默认值并继续工作。
#
# 标记说明:
#   [必填]     必须设置, 否则应用无法启动
#   [推荐]     强烈建议在公网或多人使用时启用
#   [可选]     视部署环境而定
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置 (原始变量, 不能省略)
# -----------------------------------------------------------------------------

# [必填] 数据库密码, 至少 16 位
DATABASE_PASS=change_me_to_a_strong_random_password

# [必填] Tesla API token 加密密钥 (任意 64 字符 base64 字符串).
#   生成方法: openssl rand -base64 64
ENCRYPTION_KEY=change_me_to_a_strong_random_base64_key

# [可选] 时区
TZ=Asia/Shanghai

# [可选] 默认语言
DEFAULT_LOCALE=zh_Hans

# [可选] MQTT 主机. 不需要 MQTT 时设为 DISABLE_MQTT=true.
MQTT_HOST=mosquitto

# -----------------------------------------------------------------------------
# 安全: 反代 / TLS / 鉴权
# -----------------------------------------------------------------------------

# [反代用户必填] 你的反向代理 (nginx / caddy / cloudflare) 的 IP 列表.
#   反代必须把客户端真实 IP 放进 X-Forwarded-For, 这个变量告诉 TeslaMate
#   "只有从这些 IP 来的请求, X-Forwarded-For 才可信". 未设置时 TeslaMate
#   会拒绝所有 X-Forwarded-For, 即: 永远以 socket IP 为准 (适合直连 LAN).
#   多 IP 用逗号分隔; 支持 CIDR, 例如: 172.18.0.0/16
#   1panel + nginx 容器同网络时填 nginx 容器的 IP, 例:
TESLAMATE_TRUSTED_PROXIES=

# [可选] 把外部协议告诉 TeslaMate, 让 url_for / 重定向生成 https://.
#   反代务必在转发时附加 X-Forwarded-Proto: https. 默认 false (内部 HTTP).
TESLAMATE_FORCE_SSL=false

# [可选] 由 TeslaMate 自己发送 HSTS 头. 反代场景下由 nginx/caddy 处理更合适,
#   默认 false. 仅在确认只对外暴露 https 时开启.
TESLAMATE_HSTS=false

# [公网部署推荐] 未登录时, 强制跳转到 /sign_in. 默认 false (兼容旧行为).
TESLAMATE_STRICT_AUTH=false

# [公网部署推荐] /api/car/*/logging/{resume,suspend} 也要登录态. 默认 false.
TESLAMATE_PROTECT_API=false

# [公网部署推荐] /api/* 跨域 POST/PUT/PATCH/DELETE 拒绝 (CSRF 加固).
#   默认 true. 关闭后, 任何来源都能调用 (除非单独再开 TESLAMATE_PROTECT_API).
TESLAMATE_API_ORIGIN_CHECK=true

# -----------------------------------------------------------------------------
# 安全: 防爆破
# -----------------------------------------------------------------------------

# [可选] 单个 IP 在窗口期内的最大失败次数. 超过则 429.
#   程序内部默认 10, 调整这里可覆盖.
TESLAMATE_LOGIN_MAX_PER_IP=10

# [可选] 单个邮箱账号在窗口期内的最大失败次数. 超过则 429.
#   程序内部默认 5, 调整这里可覆盖.
TESLAMATE_LOGIN_MAX_PER_EMAIL=5

# [可选] 速率限制时间窗 (秒). 程序内部默认 600 (10 分钟).
TESLAMATE_LOGIN_WINDOW_SECONDS=600

# [可选] 登录审计 ETS ring buffer 大小. 程序内部默认 100.
TESLAMATE_LOGIN_AUDIT_CAPACITY=100

# -----------------------------------------------------------------------------
# Grafana 反代 / 嵌入
# -----------------------------------------------------------------------------

# [可选] Grafana 反代开关. 启用后 /dashboards/* 由 TeslaMate 反代 Grafana.
#   默认 true. 关闭后用户跳到原 :3000 端口 (你仍然需要在 compose 里 expose).
EMBED_GRAFANA=true

# [可选] Grafana 内部地址 (TeslaMate → Grafana). 一般不需要改.
GRAFANA_UPSTREAM=http://grafana:3000

# [EMBED_GRAFANA=false 时必填] 用户浏览器能访问的 Grafana URL. 用于
#   302 重定向到旧路径. 例: https://grafana.example.com 或 http://内网IP:3000
GRAFANA_PUBLIC_URL=

# [可选] Grafana auth_proxy 使用的用户名. 默认即可.
GRAFANA_PROXY_USER=teslamate@local

# -----------------------------------------------------------------------------
# 杂项
# -----------------------------------------------------------------------------

# [可选] Grafana 自身响应的根 URL (供 Grafana 自己重定向使用).
#   启用 EMBED_GRAFANA 时填: https://your-domain.com/dashboards
GF_SERVER_ROOT_URL=http://localhost:4000/dashboards

# -----------------------------------------------------------------------------
# 不需要改的高级设置 (参考)
# -----------------------------------------------------------------------------

# TESLA_API_HOST=https://owner-api.vn.cloud.tesla.cn   # 强制走中国区 API
# TESLA_WSS_HOST=wss://streaming.vn.cloud.tesla.cn     # 强制走中国区 streaming
# TESLA_AUTH_HOST=https://auth.tesla.com               # 第三方登录门户 (中国用 cn)
# TESLAMATE_REVISION=                                  # 镜像构建参数, 1panel 不用管
# HTTP_POOL_SIZE=5                                     # HTTP 连接池大小
# HTTP_POOL_TIMEOUT=10000                              # HTTP 超时 ms